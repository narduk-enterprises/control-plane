{
  "$schema": "https://raw.githubusercontent.com/cloudflare/workers-sdk/main/packages/wrangler/schemas/config/wrangler.json",
  "name": "control-plane",
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public"
  },
  "compatibility_date": "2026-03-11",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "control-plane-db",
      "database_id": "780d8b62-72d5-4311-8559-31b3e360d070"
    }
  ],
  "triggers": {
    "crons": [
      "0 * * * *"
    ]
  },
  "routes": [
    {
      "pattern": "control-plane.nard.uk",
      "custom_domain": true
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "0c118b5181dd45e88e7dcc4d17cee9dc",
      "preview_id": "0586cd454f3745fab560cd389b7bd46d"
    }
  ]
}
