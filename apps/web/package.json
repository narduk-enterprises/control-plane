{
  "name": "web",
  "type": "module",
  "private": true,
  "version": "1.32.6",
  "imports": {
    "#server/*": "./server/*.ts"
  },
  "scripts": {
    "build": "nuxt build",
    "predev": "pnpm run db:ready",
    "dev": "(doppler run -- nuxt dev || nuxt dev)",
    "db:migrate": "bash ../../tools/db-migrate.sh control-plane-db --local --dir node_modules/@narduk-enterprises/narduk-nuxt-template-layer/drizzle --dir drizzle",
    "db:seed": "wrangler d1 execute control-plane-db --local --file=node_modules/@narduk-enterprises/narduk-nuxt-template-layer/drizzle/seed.sql",
    "db:seed:fleet": "wrangler d1 execute control-plane-db --local --file=../../tools/seed-fleet-apps.sql",
    "db:studio": "drizzle-kit studio",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "deploy": "nuxt build && wrangler deploy",
    "tail:prod": "wrangler tail control-plane --format pretty",
    "prelint": "test -f .nuxt/eslint.config.mjs || nuxt prepare",
    "lint": "eslint . --max-warnings 0",
    "test:hydration": "node scripts/hydration-smoke.mjs",
    "test:integration": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run tests/unit --config vitest.config.ts",
    "quality": "echo 'Turbo dependsOn handles lint + typecheck + format:check'",
    "db:reset": "bash ../../tools/db-migrate.sh control-plane-db --local --dir node_modules/@narduk-enterprises/narduk-nuxt-template-layer/drizzle --dir drizzle --reset && pnpm run db:seed",
    "db:ready": "pnpm run db:migrate && pnpm run db:seed",
    "db:verify": "node node_modules/@narduk-enterprises/narduk-nuxt-template-layer/testing/verify-local-db.mjs ."
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.2",
    "@narduk-enterprises/narduk-nuxt-template-layer": "workspace:*",
    "chart.js": "^4.5.1",
    "chartjs-plugin-annotation": "^3.1.0",
    "chartjs-plugin-zoom": "^2.2.0",
    "drizzle-orm": "^0.45.1",
    "libsodium-wrappers": "^0.8.2",
    "nuxt": "^4.3.1",
    "pinia": "^3.0.4",
    "postgres": "^3.4.7",
    "vue-chartjs": "^5.3.3",
    "zod": "^4.3.6",
    "@narduk-enterprises/eslint-config": "^1.0.17"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260226.0",
    "@tailwindcss/vite": "^4.0.0",
    "eslint": "^9.39.4",
    "nitro-cloudflare-dev": "^0.2.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.20.0"
  },
  "overrides": {
    "@cloudflare/unenv-preset": "2.12.1",
    "vite": "npm:rolldown-vite@7.3.1"
  },
  "volta": {
    "node": "22.22.0"
  }
}
